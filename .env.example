DB_PASSWORD=solidata_secure_password_2026
JWT_SECRET=solidata-jwt-secret-change-in-production
# Clé de chiffrement des rapports PCM — doit être différente de JWT_SECRET
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PCM_ENCRYPTION_KEY=
BREVO_API_KEY=
OPENAGENDA_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Web Push (Niveau 2.2) — Générer les clés une fois :
#   npx web-push generate-vapid-keys
# Puis renseigner VAPID_PUBLIC_KEY (exposée au client) et VAPID_PRIVATE_KEY (privée).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@solidata.online

# ───────────────────────────────────────────
# Capteurs LoRaWAN CAV — Orange Live Objects
# ───────────────────────────────────────────
LIVEOBJECTS_ENABLED=false
LIVEOBJECTS_MQTT_URL=mqtts://liveobjects.orange-business.com:8883
LIVEOBJECTS_API_KEY=
LIVEOBJECTS_FIFO_NAME=solidata-cav-uplinks
LIVEOBJECTS_WEBHOOK_SECRET=
LORA_APPKEY_ENCRYPTION_KEY=
# Fenêtre durant laquelle une lecture capteur est considérée "fraîche" pour /fill-rate
# Au-delà, le badge passe en "sensor_stale" mais la valeur reste affichée si présente
SENSOR_FRESHNESS_HOURS=48

# ───────────────────────────────────────────
# Webhook Power Automate — import auto CSV LogicS dans /api/boutique-ventes/webhook-email
# Doit être passé en header X-Webhook-Secret par le flow Power Automate.
# Générer : node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# ───────────────────────────────────────────
BOUTIQUE_WEBHOOK_SECRET=
