DB_HOST=localhost
DB_PORT=5432
DB_NAME=solidata
DB_USER=solidata_user
DB_PASSWORD=solidata_secure_password_2026
JWT_SECRET=solidata-jwt-secret-change-in-production
# Clé de chiffrement des rapports PCM — doit être différente de JWT_SECRET
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PCM_ENCRYPTION_KEY=
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
BREVO_API_KEY=
CENTRE_TRI_LAT=49.4231
CENTRE_TRI_LNG=1.0993

# ───────────────────────────────────────────
# Capteurs LoRaWAN CAV — Orange Live Objects
# ───────────────────────────────────────────
# Flag principal : met à true pour activer le worker MQTT
LIVEOBJECTS_ENABLED=false
# Broker MQTT Orange Live Objects
LIVEOBJECTS_MQTT_URL=mqtts://liveobjects.orange-business.com:8883
# API key Live Objects (rôle minimum BUS_READ) — username MQTT = "application"
LIVEOBJECTS_API_KEY=
# Nom de la FIFO Live Objects routant les uplinks LoRa (créée côté plateforme)
LIVEOBJECTS_FIFO_NAME=solidata-cav-uplinks
# Secret partagé pour le webhook HTTP (fallback) — à configurer aussi côté Live Objects
LIVEOBJECTS_WEBHOOK_SECRET=
# Clé de chiffrement AES-256 des AppKey LoRaWAN stockées (fallback: JWT_SECRET)
LORA_APPKEY_ENCRYPTION_KEY=
# Fenêtre de fraîcheur capteur — au-delà on retombe sur l'heuristique
SENSOR_FRESHNESS_HOURS=8

# ───────────────────────────────────────────
# Webhook Power Automate — imports boutiques
# ───────────────────────────────────────────
# Secret partagé pour le webhook HTTP Power Automate (réception CSV Outlook)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Doit être identique côté Power Automate (header X-Webhook-Secret)
BOUTIQUE_WEBHOOK_SECRET=
